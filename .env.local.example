# ── AI providers ────────────────────────────────────────────────────────────
# At least one must be set. If both are set, Qwen is preferred (local / free).

# Anthropic Claude (any model)
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-3-5-haiku-20241022

# Qwen32B on DGX Spark, Ollama, or NVIDIA NIM
# Set to the base URL of your OpenAI-compatible server (no trailing slash).
# e.g. http://localhost:11434   (Ollama)
#      http://localhost:8080    (NIM)
#      http://192.168.1.50:11434
QWEN_ENDPOINT=
QWEN_MODEL=qwen2.5:32b

# ── Directus ─────────────────────────────────────────────────────────────────
# Server-side Directus credentials — never sent to the browser.
DIRECTUS_URL=https://your-directus.io
DIRECTUS_TOKEN=

# ── SQLite database path ──────────────────────────────────────────────────────
# Absolute path or relative to project root. Directory will be auto-created.
SQLITE_PATH=./data/fish-intel.db
