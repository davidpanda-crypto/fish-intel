# ── API security ─────────────────────────────────────────────────────────────
# Set both to the same random string (e.g. openssl rand -hex 32).
# API_SECRET       — server-only, protects /api/db/* routes (never in JS bundle)
# NEXT_PUBLIC_API_SECRET — baked into client JS, protects /api/ai and /api/scrape
# Leave unset in local development (auth is skipped when unset).
API_SECRET=
NEXT_PUBLIC_API_SECRET=

# ── AI providers ────────────────────────────────────────────────────────────
# At least one must be set. If both are set, Qwen is preferred (local / free).

# Anthropic Claude (any model)
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-3-5-haiku-20241022

# Qwen32B on DGX Spark, Ollama, or NVIDIA NIM
# Set to the base URL of your OpenAI-compatible server (no trailing slash).
# e.g. http://localhost:11434   (Ollama)
#      http://localhost:8080    (NIM)
#      http://192.168.1.50:11434
QWEN_ENDPOINT=
QWEN_MODEL=qwen2.5:32b

# ── Directus ─────────────────────────────────────────────────────────────────
# Server-side Directus credentials — never sent to the browser.
DIRECTUS_URL=https://your-directus.io
DIRECTUS_TOKEN=

# ── SQLite database path ──────────────────────────────────────────────────────
# LOCAL / VPS: set to an absolute path outside the project for persistence.
#   SQLITE_PATH=/var/data/fish-intel.db
#
# VERCEL: leave unset — defaults to /tmp/fish-intel.db (writable, but ephemeral
# between cold starts). All user data is stored client-side in sql.js / IDB,
# so the server DB is a warm cache and data loss on cold start is acceptable.
# For a persistent server-side store on Vercel, use Vercel Postgres or Turso.
SQLITE_PATH=
